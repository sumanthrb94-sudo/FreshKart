             items.size() == 41 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal :
             items.size() == 42 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal :
             items.size() == 43 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal :
             items.size() == 44 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal + items[43].lineTotal :
             items.size() == 45 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal + items[43].lineTotal + items[44].lineTotal :
             items.size() == 46 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal + items[43].lineTotal + items[44].lineTotal + items[45].lineTotal :
             items.size() == 47 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal + items[43].lineTotal + items[44].lineTotal + items[45].lineTotal + items[46].lineTotal :
             items.size() == 48 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal + items[43].lineTotal + items[44].lineTotal + items[45].lineTotal + items[46].lineTotal + items[47].lineTotal :
             items.size() == 49 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal + items[43].lineTotal + items[44].lineTotal + items[45].lineTotal + items[46].lineTotal + items[47].lineTotal + items[48].lineTotal :
             items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal + items[32].lineTotal + items[33].lineTotal + items[34].lineTotal + items[35].lineTotal + items[36].lineTotal + items[37].lineTotal + items[38].lineTotal + items[39].lineTotal + items[40].lineTotal + items[41].lineTotal + items[42].lineTotal + items[43].lineTotal + items[44].lineTotal + items[45].lineTotal + items[46].lineTotal + items[47].lineTotal + items[48].lineTotal + items[49].lineTotal;
    }

    // Allowed top-level fields on a new order document. Prevents buyers from
    // injecting arbitrary keys (e.g. `isAdmin`, `discount`, `refundAmount`)
    // into the order document.
    function hasOnlyOrderFields() {
      return request.resource.data.keys().hasOnly([
        'buyerId', 'businessName', 'items', 'status', 'paymentMethod',
        'paymentStatus', 'subtotal', 'deliveryFee', 'total', 'delivery',
        'createdAt', 'updatedAt', 'orderNumber', 'deliveredAt'
      ]);
    }

    // Buyer cancel: only the `status`, `updatedAt`, and `notes` fields may change.
    function onlyCancelFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt', 'notes']);
    }

    // --- Products: public catalog. Admins manage; signed-in users may only
    //     adjust stock (order/cancel transactions). ---
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && onlyStockChanged() && isStockChangeValid());
    }

    // --- Users: a user reads/edits their own profile; admins read all.
    //     Self-signup may only create a BUYER and cannot self-promote. ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && (request.resource.data.role == 'BUYER' || isAdminEmail());
      allow update: if isAdmin()
                    || (request.auth.uid == userId
                        && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // --- Email/phone uniqueness claims: id = the normalized email or phone,
    //     value = { uid }. A signed-in user may only claim a slot nobody else
    //     already owns (this is how onboarding enforces one account per
    //     email/phone) — never listed or read back, so no buyer's email/phone
    //     is ever exposed to another buyer. See src/lib/api/firebase.ts
    //     completeProfile()/claimUnique().
    function isOwnUidOnlyDoc() {
      return request.resource.data.keys().hasOnly(['uid'])
             && request.resource.data.uid == request.auth.uid;
    }
    match /emailIndex/{email} {
      allow get, list: if false;
      allow create: if isSignedIn() && isOwnUidOnlyDoc();
      allow update: if isSignedIn() && isOwnUidOnlyDoc() && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
    match /phoneIndex/{phone} {
      allow get, list: if false;
      allow create: if isSignedIn() && isOwnUidOnlyDoc();
      allow update: if isSignedIn() && isOwnUidOnlyDoc() && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Allowed top-level fields on a new return document.
    function hasOnlyReturnFields() {
      return request.resource.data.keys().hasOnly([
        'buyerId', 'businessName', 'buyerPhone', 'orderId', 'orderNumber',
        'items', 'status', 'reason', 'notes', 'requestedAt', 'totalRefund',
        'adjustedInvoiceNumber', 'images', 'thread', 'updatedAt', 'resolvedAt'
      ]);
    }

    // Buyer reply: only the thread and updatedAt may change, and the thread must grow.
    function isBuyerReturnReply() {
      return resource.data.buyerId == request.auth.uid
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['thread', 'updatedAt'])
             && request.resource.data.thread.size() == resource.data.thread.size() + 1;
    }

    // --- Returns: buyer creates/reads/replies on their own; admins manage all. ---
    match /returns/{returnId} {
      allow read: if isSignedIn()
                  && (resource.data.buyerId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.status == 'REQUESTED'
                    && hasOnlyReturnFields()
                    && request.resource.data.items.size() > 0
                    // Matches the order item cap — a return can never have
                    // more items than the order it's for.
                    && request.resource.data.items.size() <= 50;

      allow update: if isAdmin()
                    || isBuyerReturnReply();

      allow delete: if isAdmin();
    }

    // --- Orders: a buyer creates/reads/cancels their own; admins manage all. ---
    match /orders/{orderId} {
      allow read: if isSignedIn()
                  && (resource.data.buyerId == request.auth.uid || isAdmin());
      // Buyers create their own auto-confirmed orders; admins (POS / phone desk) may
      // place an order on behalf of any buyer. Field whitelist prevents
      // injection of arbitrary keys (e.g. `discount`, `isAdmin`).
      allow create: if isAdmin()
                    || (isSignedIn()
                        && hasOnlyOrderFields()
                        && request.resource.data.buyerId == request.auth.uid
                        && request.resource.data.status in ['CONFIRMED']
                        && request.resource.data.paymentMethod in ['COD', 'ONLINE']
                        && validateOrderItems(
                             request.resource.data.items,
                             get(/databases/$(database)/documents/settings/priceSheet).data.prices)
                        && request.resource.data.subtotal == getExpectedSubtotal(request.resource.data.items)
                        && request.resource.data.deliveryFee == getExpectedDeliveryFee(request.resource.data.subtotal)
                        && request.resource.data.total == request.resource.data.subtotal + request.resource.data.deliveryFee);
      // Admin can advance to any status; a buyer may only cancel while the
      // order is still PENDING/CONFIRMED and may ONLY change `status`,
      // `updatedAt`, and `notes` (cannot tamper with items, totals, etc.).
      allow update: if isAdmin()
                    || (resource.data.buyerId == request.auth.uid
                        && resource.data.status in ['PENDING', 'CONFIRMED']
                        && request.resource.data.status == 'CANCELLED'
                        && onlyCancelFieldsChanged());
      allow delete: if isAdmin();
    }
  }
}
