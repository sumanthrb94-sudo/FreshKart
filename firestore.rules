rules_version = '2';

// FreshKart Firestore Security Rules.
// The browser talks to Firestore directly, so these rules ARE the backend's
// authorization layer. See docs/FIREBASE.md.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Emails granted ADMIN regardless of their stored role. Keep in sync with
    // ADMIN_EMAILS in src/lib/api/firebase.ts.
    function isAdminEmail() {
      return isSignedIn()
             && request.auth.token.email in ['sumanthbolla97@gmail.com'];
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAdminEmail() || (isSignedIn() && userRole() == 'ADMIN');
    }

    // Only the `stock` field is being changed.
    function onlyStockChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']);
    }

    // Stock must only be decremented (not incremented or set arbitrarily)
    // and by at most 500 units at a time.
    function isStockDecrementValid() {
      return request.resource.data.stock < resource.data.stock
             && resource.data.stock - request.resource.data.stock <= 500;
    }

    // Helper to validate a single order item's price and line total integrity
    function validateItem(item) {
      return item.price == get(/databases/$(database)/documents/products/$(item.productId)).data.price
             && item.lineTotal == item.price * item.qty;
    }

    // Helper to validate order items array up to length of 10
    function validateOrderItems(items) {
      return items.size() > 0 && items.size() <= 10
             && (items.size() < 1 || validateItem(items[0]))
             && (items.size() < 2 || validateItem(items[1]))
             && (items.size() < 3 || validateItem(items[2]))
             && (items.size() < 4 || validateItem(items[3]))
             && (items.size() < 5 || validateItem(items[4]))
             && (items.size() < 6 || validateItem(items[5]))
             && (items.size() < 7 || validateItem(items[6]))
             && (items.size() < 8 || validateItem(items[7]))
             && (items.size() < 9 || validateItem(items[8]))
             && (items.size() < 10 || validateItem(items[9]));
    }

    // Helper to compute expected subtotal from order items
    function getExpectedSubtotal(items) {
      return items.size() == 1 ? items[0].lineTotal :
             items.size() == 2 ? items[0].lineTotal + items[1].lineTotal :
             items.size() == 3 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal :
             items.size() == 4 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal :
             items.size() == 5 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal :
             items.size() == 6 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal :
             items.size() == 7 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal :
             items.size() == 8 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal :
             items.size() == 9 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal :
             items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal;
    }

    // Allowed top-level fields on a new order document. Prevents buyers from
    // injecting arbitrary keys (e.g. `isAdmin`, `discount`, `refundAmount`)
    // into the order document.
    function hasOnlyOrderFields() {
      return request.resource.data.keys().hasOnly([
        'buyerId', 'businessName', 'items', 'status', 'paymentMethod',
        'paymentStatus', 'subtotal', 'deliveryFee', 'total', 'delivery',
        'createdAt', 'updatedAt', 'orderNumber'
      ]);
    }

    // Buyer cancel: only the `status` and `updatedAt` fields may change.
    function onlyStatusChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt']);
    }

    // --- Products: public catalog. Admins manage; signed-in users may only
    //     adjust stock (order/cancel transactions). ---
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && onlyStockChanged() && isStockDecrementValid());
    }

    // --- Users: a user reads/edits their own profile; admins read all.
    //     Self-signup may only create a BUYER and cannot self-promote. ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && (request.resource.data.role == 'BUYER' || isAdminEmail());
      allow update: if isAdmin()
                    || (request.auth.uid == userId
                        && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // --- Orders: a buyer creates/reads/cancels their own; admins manage all. ---
    match /orders/{orderId} {
      allow read: if isSignedIn()
                  && (resource.data.buyerId == request.auth.uid || isAdmin());
      // Buyers create their own PENDING orders; admins (POS / phone desk) may
      // place an order on behalf of any buyer. Field whitelist prevents
      // injection of arbitrary keys (e.g. `discount`, `isAdmin`).
      allow create: if isAdmin()
                    || (isSignedIn()
                        && hasOnlyOrderFields()
                        && request.resource.data.buyerId == request.auth.uid
                        && request.resource.data.status == 'PENDING'
                        && validateOrderItems(request.resource.data.items)
                        && request.resource.data.subtotal == getExpectedSubtotal(request.resource.data.items)
                        && request.resource.data.total == request.resource.data.subtotal);
      // Admin can advance to any status; a buyer may only cancel while the
      // order is still PENDING or CONFIRMED and may ONLY change `status` +
      // `updatedAt` (cannot tamper with items, totals, or other fields).
      allow update: if isAdmin()
                    || (resource.data.buyerId == request.auth.uid
                        && resource.data.status in ['PENDING', 'CONFIRMED']
                        && request.resource.data.status == 'CANCELLED'
                        && onlyStatusChanged());
      allow delete: if isAdmin();
    }
  }
}
