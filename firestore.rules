rules_version = '2';

// Green Basket Firestore Security Rules.
// The browser talks to Firestore directly, so these rules ARE the backend's
// authorization layer. See docs/FIREBASE.md.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Emails granted ADMIN regardless of their stored role. Keep in sync with
    // ADMIN_EMAILS in src/lib/api/firebase.ts.
    function isAdminEmail() {
      return isSignedIn()
             && request.auth.token.email in ['sumanthbolla97@gmail.com', 'sivakishore43@gmail.com'];
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAdminEmail() || (isSignedIn() && userRole() == 'ADMIN');
    }

    // Only the `stock` field is being changed.
    function onlyStockChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']);
    }

    // --- Settings: daily price-update gate. World-readable; admin-writable. ---
    match /settings/dailyPrices {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // --- Settings: live price mirror ({ prices: { productId: price } }),
    //     kept in sync by updateProduct/createProduct/updateProductPrices in
    //     src/lib/api/firebase.ts on every price-changing admin write. The
    //     order-create rule reads this ONE document instead of doing a
    //     get() per line item — that's what lets a cart carry any number of
    //     distinct products instead of being capped by Firestore's
    //     get()-call budget per rule evaluation. World-readable (prices are
    //     already public via the products catalog); admin-writable only.
    match /settings/priceSheet {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Signed-in buyers reserve/release stock during order/cancel transactions.
    // The change must only touch `stock` and may move by at most 10,000 units
    // (either direction) — generous headroom above any realistic single bulk
    // B2B order, while still blocking a wildly out-of-range write. (This was
    // previously capped at 500, which a legitimate bulk order could exceed on
    // its own — e.g. ordering 550kg of an item seeded with 600kg of stock —
    // failing the whole checkout with "Missing or insufficient permissions".)
    function isStockChangeValid() {
      return request.resource.data.stock >= 0
             && request.resource.data.stock <= resource.data.stock + 10000
             && request.resource.data.stock >= resource.data.stock - 10000;
    }

    // Helper to validate a single order item's price and line total integrity.
    // `prices` is the pre-fetched settings/priceSheet map — passed in so this
    // makes ZERO get() calls of its own, unlike the old per-item
    // get(products/{id}) lookup. That's what removes the item-count ceiling
    // that used to be forced by Firestore's get()-call budget per rule
    // evaluation (10 for a single doc, 20 inside a transaction).
    function validateItem(item, prices) {
      return item.price == prices[item.productId]
             && item.lineTotal == item.price * item.qty;
    }

    // Validates every item in the cart in one pass via the `all()` CEL macro
    // — no per-item unrolling, so price/lineTotal checks work for any array
    // length. The `<= 50` below exists purely because getExpectedSubtotal()
    // has to be hand-unrolled (Firestore rules have no loop/reduce construct
    // to sum an arbitrary-length array) — it is NOT a get()-budget limit
    // anymore, and 50 is comfortably above the entire product catalog, so no
    // real cart can ever hit it. The client mirrors the same number via
    // MAX_ORDER_ITEM_TYPES in src/lib/format.ts.
    function validateOrderItems(items, prices) {
      return items.size() > 0 && items.size() <= 50
             && items.all(item, validateItem(item, prices));
    }
    // Delivery fee slab based on subtotal (in rupees).
    function getExpectedDeliveryFee(subtotal) {
      return subtotal <= 0 ? 0 :
             subtotal <= 1000 ? 75 :
             subtotal <= 3000 ? 50 :
             0;
    }

    // Helper to compute expected subtotal from order items. Unrolled up
    // to 50 (matches the size cap in validateOrderItems /
    // MAX_ORDER_ITEM_TYPES client-side) since there's no sum/reduce macro
    // in Firestore's rules language — this is pure arithmetic with no
    // get() calls, so it isn't bound by any call-budget limit, only by
    // how far it's been hand-unrolled.
    function getExpectedSubtotal(items) {
      return items.size() == 1 ? items[0].lineTotal :
             items.size() == 2 ? items[0].lineTotal + items[1].lineTotal :
             items.size() == 3 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal :
             items.size() == 4 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal :
             items.size() == 5 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal :
             items.size() == 6 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal :
             items.size() == 7 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal :
             items.size() == 8 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal :
             items.size() == 9 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal :
             items.size() == 10 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal :
             items.size() == 11 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal :
             items.size() == 12 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal :
             items.size() == 13 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal :
             items.size() == 14 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal :
             items.size() == 15 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal :
             items.size() == 16 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal :
             items.size() == 17 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal :
             items.size() == 18 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal :
             items.size() == 19 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal :
             items.size() == 20 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal :
             items.size() == 21 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal :
             items.size() == 22 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal :
             items.size() == 23 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal :
             items.size() == 24 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal :
             items.size() == 25 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal :
             items.size() == 26 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal :
             items.size() == 27 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal :
             items.size() == 28 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal :
             items.size() == 29 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal :
             items.size() == 30 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal :
             items.size() == 31 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal :
             items.size() == 32 ? items[0].lineTotal + items[1].lineTotal + items[2].lineTotal + items[3].lineTotal + items[4].lineTotal + items[5].lineTotal + items[6].lineTotal + items[7].lineTotal + items[8].lineTotal + items[9].lineTotal + items[10].lineTotal + items[11].lineTotal + items[12].lineTotal + items[13].lineTotal + items[14].lineTotal + items[15].lineTotal + items[16].lineTotal + items[17].lineTotal + items[18].lineTotal + items[19].lineTotal + items[20].lineTotal + items[21].lineTotal + items[22].lineTotal + items[23].lineTotal + items[24].lineTotal + items[25].lineTotal + items[26].lineTotal + items[27].lineTotal + items[28].lineTotal + items[29].lineTotal + items[30].lineTotal + items[31].lineTotal :
