# ----------------------------------------------------------------------------
# FreshKart environment configuration
# Copy to `.env.local` for local development. Configure the same vars in Vercel.
# ----------------------------------------------------------------------------

# Data source selection
# Leave EMPTY (or unset) to run the built-in MOCK data layer (in-memory + the
# browser's localStorage). Set it to your deployed GCP backend base URL to make
# the frontend talk to the real API instead — e.g. a Cloud Run service.
#
#   NEXT_PUBLIC_API_BASE_URL=https://freshkart-api-xxxxxx.a.run.app
NEXT_PUBLIC_API_BASE_URL=

# Public app name / metadata (optional)
NEXT_PUBLIC_APP_NAME=FreshKart

# ----------------------------------------------------------------------------
# The variables below are NOT used by the current mock frontend. They are
# placeholders documenting what the GCP backend will need once you build it.
# Keep secrets in Vercel/GCP secret managers — never commit real values.
# ----------------------------------------------------------------------------

# Postgres (Cloud SQL) connection string used by the future backend
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/freshkart

# Auth / session signing secret (backend)
# AUTH_SECRET=change-me

# Payment gateway (Razorpay) — the UI ships a simulated/mock gateway by default
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
