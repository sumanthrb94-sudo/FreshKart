# ----------------------------------------------------------------------------
# FreshKart environment configuration
# Copy to `.env.local` for local development. Configure the same vars in Vercel.
# ----------------------------------------------------------------------------

# ============================================================================
# BACKEND: Firebase (Firestore + Auth + Storage) — the chosen production backend
# ----------------------------------------------------------------------------
# When these are set, the app talks to Firebase DIRECTLY from the browser
# (no separate server). Leave them empty to run the in-browser MOCK backend
# for local dev. Find these values in Firebase console →
# Project settings → General → "Your apps" → SDK setup and configuration.
# All NEXT_PUBLIC_* values are safe to expose to the client (Firebase web config
# is not a secret; security is enforced by Firestore/Storage rules).
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics when set
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Public app name / metadata (optional)
NEXT_PUBLIC_APP_NAME=FreshKart

# ----------------------------------------------------------------------------
# Seeding (server-side, Admin SDK) — used by `npm run seed:firestore` only.
# Point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON file, OR paste
# the JSON into FIREBASE_SERVICE_ACCOUNT_JSON. NEVER commit these values.
# ----------------------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ----------------------------------------------------------------------------
# OPTIONAL alternative backend: a custom REST API (instead of Firebase).
# Only used when the NEXT_PUBLIC_FIREBASE_* vars above are NOT set.
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL=https://freshkart-api-xxxxxx.a.run.app
